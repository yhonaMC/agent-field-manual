---
import ManualLayout from "../layouts/ManualLayout.astro";
import ReviewDeck from "../components/islands/ReviewDeck";
---
<ManualLayout title="Repaso" description="Repaso espaciado de cada pregunta que has fallado, con recordatorios a 1, 3, 7, 16 y 35 días.">
  <div class="hero" style="padding:clamp(2.4rem,5vw,3.6rem) 0; border-bottom:var(--heavy)">
    <span class="eyebrow">Repaso espaciado · 1·3·7·16·35 días</span>
    <h1 style="font-size:clamp(2.2rem,6vw,4rem); margin-top:1rem">Mazo de repaso</h1>
    <p class="lead">Cada pregunta que fallas en cualquier parte del manual se programa aquí a 1, 3, 7, 16 y luego 35 días. Vacía la cola cada día.</p>
  </div>
  <section>
    <ReviewDeck client:load />
  </section>
</ManualLayout>
