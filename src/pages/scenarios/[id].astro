---
import { getCollection, render } from "astro:content";
import ManualLayout from "../../layouts/ManualLayout.astro";

export async function getStaticPaths() {
  const scenarios = await getCollection("scenarios");
  return scenarios.map((s) => ({ params: { id: String(s.data.order) }, props: { entry: s } }));
}
const { entry } = Astro.props;
const { Content } = await render(entry);
---
<ManualLayout title={entry.data.title} description={entry.data.summary}>
  <div class="hero" style="padding:clamp(2.4rem,5vw,3.6rem) 0; border-bottom:var(--heavy)">
    <span class="eyebrow">Escenario {String(entry.data.order).padStart(2, "0")}</span>
    <h1 style="font-size:clamp(2rem,5vw,3.4rem); max-width:24ch; margin-top:1rem">{entry.data.title}</h1>
  </div>
  <section>
    <article class="prose">
      <Content />
    </article>
  </section>
</ManualLayout>
