---
import { getCollection, render } from "astro:content";
import ManualLayout from "../../../layouts/ManualLayout.astro";
import LessonFooter from "../../../components/islands/LessonFooter";

export async function getStaticPaths() {
  const lessons = await getCollection("lessons");
  return lessons.map((l) => ({
    params: { domain: String(l.data.domain), chapter: l.id.split("/")[1] },
    props: { entry: l },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---
<ManualLayout title={entry.data.title} description={entry.data.summary}>
  <div class="hero" style="padding:clamp(2.4rem,5vw,3.6rem) 0; border-bottom:var(--heavy)">
    <span class="eyebrow"><a href={`/manual/${entry.data.domain}`} style="color:inherit; text-decoration:none">Dominio {String(entry.data.domain).padStart(2, "0")}</a></span>
    <h1 style="font-size:clamp(2rem,5vw,3.4rem); max-width:24ch; margin-top:1rem">{entry.data.title}</h1>
  </div>
  <section>
    <article class="prose">
      <Content />
    </article>
    <LessonFooter client:visible lessonId={entry.id} domain={entry.data.domain} />
  </section>
</ManualLayout>
