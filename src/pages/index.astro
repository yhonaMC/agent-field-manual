---
import { getCollection } from "astro:content";
import ManualLayout from "../layouts/ManualLayout.astro";
import DomainIndex, { type DomainRow } from "../components/islands/DomainIndex";
import { practiceQuestions } from "../lib/question-bank";

const domains = (await getCollection("domains")).sort((a, b) => a.data.domain - b.data.domain);
const lessons = await getCollection("lessons");

const rows: DomainRow[] = domains.map((d) => ({
  domain: d.data.domain,
  title: d.data.title,
  summary: d.data.summary,
  lessonCount: lessons.filter((l) => l.data.domain === d.data.domain).length,
  questionIds: practiceQuestions(d.data.domain).map((q) => q.id),
}));
---
<ManualLayout
  title="Estudia para la certificación de Claude"
  description="Manual de campo para la certificación de agentes de Claude (CCAF): 18 lecciones, más de 190 preguntas y un simulador de examen de 60 preguntas. Sin cuenta.">

  <div class="hero">
    <div class="ghostnum" aria-hidden="true">A</div>
    <span class="eyebrow">Preparación · Certificación de Claude</span>
    <h1>Domina el examen de <span class="u">agentes de Claude.</span></h1>
    <p class="lead">
      Un manual de campo para la certificación CCAF: 18 lecciones, 190+ preguntas y un
      simulacro cronometrado idéntico al examen real. Sin cuenta — tu progreso vive en tu navegador.
    </p>
    <div class="actions">
      <a class="btn" href="/manual/1">Empezar el temario</a>
      <a class="btn ghost" href="/exam">Ir al simulacro</a>
    </div>
  </div>

  <div class="strip">
    <div class="cell"><div class="n">05</div><div class="k">dominios oficiales</div></div>
    <div class="cell"><div class="n">18</div><div class="k">lecciones guiadas</div></div>
    <div class="cell"><div class="n">190+</div><div class="k">preguntas con solución</div></div>
    <div class="cell"><div class="n">60</div><div class="k">preguntas · simulacro</div></div>
  </div>

  <section id="temario" style="scroll-margin-top:1rem">
    <div class="sechead"><h2>El temario</h2><span class="mono">Índice · 5 dominios</span></div>
    <DomainIndex client:load rows={rows} />
  </section>

  <section>
    <div class="sechead"><h2>Cómo se estudia</h2><span class="mono">Método · 3 fases</span></div>
    <div class="tracks">
      <div class="track"><div class="step">FASE 01</div><h3>Lee el manual</h3><p>18 lecciones en inglés — como el examen real — organizadas por dominio oficial.</p></div>
      <div class="track"><div class="step">FASE 02</div><h3>Practica y desbloquea</h3><p>Drills con solución explicada. Aprueba un dominio al 70% y se abre el siguiente.</p></div>
      <div class="track"><div class="step">FASE 03</div><h3>Presenta el simulacro</h3><p>60 preguntas cronometradas con desglose por dominio, igual que el día del examen.</p></div>
    </div>
  </section>

  <section>
    <div class="exam">
      <div>
        <h2>¿Listo para el simulacro?</h2>
        <p>60 preguntas, 90 minutos, sin feedback hasta enviar. Mide dónde estás antes del examen real.</p>
      </div>
      <a href="/exam" class="btn accent">Iniciar simulacro →</a>
    </div>
  </section>
</ManualLayout>
